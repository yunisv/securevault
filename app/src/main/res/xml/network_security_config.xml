<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration
    Документация: https://developer.android.com/training/articles/security-config

    Стратегия:
    — base-config: запрет HTTP + нет доверенных CA (все соединения запрещены по умолчанию)
    — domain-config: явно разрешаем ТОЛЬКО наш API-домен с Certificate Pinning
-->
<network-security-config>

    <!-- Максимально строгий base-config: запрет HTTP, нет доверенных CA -->
    <base-config cleartextTrafficPermitted="false" />

    <!-- Certificate Pinning для API-сервера — единственный разрешённый домен -->
    <domain-config>
        <domain includeSubdomains="true">api.securevault.example.com</domain>

        <!-- Доверять только системным CA для этого домена -->
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>

        <pin-set expiration="2027-06-01">
            <!--
                SHA-256 хеш SPKI основного сертификата.
                Получить: openssl s_client -connect api.example.com:443 \
                          | openssl x509 -pubkey -noout \
                          | openssl pkey -pubin -outform der \
                          | openssl dgst -sha256 -binary | base64
            -->
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
            <!-- Резервный pin для ротации сертификата -->
            <pin digest="SHA-256">BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=</pin>
        </pin-set>
    </domain-config>

</network-security-config>
