<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration — Certificate Pinning + запрет HTTP
    Документация: https://developer.android.com/training/articles/security-config
-->
<network-security-config>

    <!-- Глобальный запрет незашифрованного HTTP-трафика -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Доверять только системным CA, НЕ пользовательским -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Certificate Pinning для API-сервера -->
    <domain-config>
        <domain includeSubdomains="true">api.securevault.example.com</domain>
        <pin-set expiration="2027-06-01">
            <!--
                SHA-256 хеш SPKI основного сертификата.
                Получить: openssl s_client -connect api.example.com:443 \
                          | openssl x509 -pubkey -noout \
                          | openssl pkey -pubin -outform der \
                          | openssl dgst -sha256 -binary | base64
            -->
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
            <!-- Резервный pin для ротации сертификата -->
            <pin digest="SHA-256">BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=</pin>
        </pin-set>
    </domain-config>

    <!--
        ТОЛЬКО для Debug-сборки: разрешить пользовательские CA
        (нужно для перехвата трафика через Burp Suite при разработке).
        В Release-сборке этот блок ИГНОРИРУЕТСЯ.
    -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

</network-security-config>
